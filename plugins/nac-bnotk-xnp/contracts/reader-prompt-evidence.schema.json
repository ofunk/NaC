{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ofunk/NaC/plugins/nac-bnotk-xnp/contracts/reader-prompt-evidence.schema.json",
  "title": "XNP-Prüfung Leser-Prompt-Nachweis",
  "type": "object",
  "required": [
    "schema_version",
    "plugin",
    "prompt_id",
    "generated_at",
    "overall_status",
    "mode",
    "intent",
    "reader_prompt",
    "xnp_local_interface",
    "card_gate_evidence",
    "policy",
    "checks",
    "next_required_action"
  ],
  "properties": {
    "schema_version": {
      "const": "nac.xnp.reader-prompt/v1"
    },
    "plugin": {
      "const": "nac-bnotk-xnp"
    },
    "prompt_id": {
      "type": "string",
      "pattern": "^XNP-RP-[0-9a-fA-F-]{36}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "overall_status": {
      "enum": [
        "prompted",
        "manual_review",
        "blocked"
      ]
    },
    "mode": {
      "const": "local_dry_run"
    },
    "intent": {
      "enum": [
        "reader_function_check",
        "xnp_login_preflight",
        "online_hra_preflight"
      ]
    },
    "reader_prompt": {
      "type": "object",
      "required": [
        "target",
        "route",
        "text",
        "operator_actions",
        "dry_run_only"
      ],
      "properties": {
        "target": {
          "const": "local_cyberjack_reader"
        },
        "route": {
          "const": "nac-bnotk-xnp -> nac-cyberjack-rfid"
        },
        "text": {
          "type": "string"
        },
        "operator_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dry_run_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "xnp_local_interface": {
      "type": "object"
    },
    "card_gate_evidence": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "required": [
        "pin_captured",
        "card_data_captured",
        "xnp_api_key_captured",
        "xnp_login_performed",
        "external_network_calls",
        "localhost_only",
        "productive_xnp_write"
      ],
      "properties": {
        "pin_captured": {
          "const": false
        },
        "card_data_captured": {
          "const": false
        },
        "xnp_api_key_captured": {
          "const": false
        },
        "xnp_login_performed": {
          "const": false
        },
        "external_network_calls": {
          "const": false
        },
        "localhost_only": {
          "const": true
        },
        "productive_xnp_write": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "severity",
          "message",
          "details"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "manual_review"
            ]
          },
          "severity": {
            "enum": [
              "info",
              "manual",
              "blocker"
            ]
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "next_required_action": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
