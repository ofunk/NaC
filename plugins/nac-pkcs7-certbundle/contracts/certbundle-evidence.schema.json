{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ofunk/NaC/plugins/nac-pkcs7-certbundle/contracts/certbundle-evidence.schema.json",
  "title": "NaC PKCS7 CertBundle Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "plugin",
    "evidence_id",
    "generated_at",
    "overall_status",
    "mode",
    "policy",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "nac.pkcs7-certbundle.evidence/v1"
    },
    "plugin": {
      "const": "nac-pkcs7-certbundle"
    },
    "evidence_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "overall_status": {
      "enum": [
        "ready",
        "manual_review",
        "blocked"
      ]
    },
    "mode": {
      "const": "local_metadata_only"
    },
    "input": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "required": [
        "local_only",
        "external_network_calls",
        "private_key_loaded",
        "pkcs12_pfx_imported",
        "pin_captured",
        "signature_created",
        "signature_verified",
        "certificate_material_stored"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "severity",
          "message",
          "details"
        ]
      }
    },
    "next_required_action": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
